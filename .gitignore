# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-admin/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Large/private artifacts (don't push to git)
bisma-site*.zip
out.zip
out/
prisma/dev.db
prisma/dev.db-journal

# Uploaded media — never in git, lives on server in /var/www/uploads
/public/uploads/
public/uploads/

# Local-only deploy reference (contains secrets, never commit)
for-deploy.txt
